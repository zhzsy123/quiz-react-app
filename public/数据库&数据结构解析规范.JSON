            "构造冲突图或等价分析",
            "给出正确结论"
          ]
        }
      }
    },
    "composite": {
      "required": [
        "id",
        "type",
        "prompt",
        "questions"
      ],
      "constraints": [
        "composite 是唯一新增顶层结构",
        "composite 不允许嵌套",
        "reading / cloze 不允许作为 composite 子题",
        "composite 子题只允许 single_choice / multiple_choice / true_false / fill_blank / short_answer / calculation / operation / case_analysis",
        "composite.score 必须等于所有子题 score 之和"
      ],
      "example": {
        "id": "comp_1",
        "type": "composite",
        "prompt": "阅读下列事务调度并回答问题。",
        "material_title": "Transaction schedule",
        "material": "T1: read(A); T2: write(A);",
        "material_format": "sql",
        "presentation": "code",
        "deliverable_type": "transaction_analysis",
        "score": 8,
        "tags": [
          "transaction",
          "concurrency"
        ],
        "assets": [],
        "questions": [
          {
            "id": "q1",
            "type": "true_false",
            "prompt": "该调度是冲突可串行化的。",
            "score": 2,
            "answer": {
              "correct": "F"
            }
          },
          {
            "id": "q2",
            "type": "short_answer",
            "prompt": "说明理由。",
            "score": 6,
            "response_format": "analysis",
            "answer": {
              "reference_answer": "根据冲突图存在环，因此不可串行化。",
              "scoring_points": [
                "指出冲突关系",
                "说明存在环",
                "得出不可串行化结论"
              ]
            }
          }
        ]
      }
    }
  },
  "frozen_contracts": {
    "canonical_fields": [
      "composite_context",
      "questionKey",
      "itemsSnapshot",
      "answers[compositeId][subQuestionId]",
      "revealedMap[`${compositeId}:${subQuestionId}`]"
    ],
    "question_key_rules": {
      "regular_question": "沿用题目自身 questionId / 原规则",
      "composite_sub_question": "${compositeId}:${subQuestionId}"
    },
    "notes": [
      "DeepSeek 只需要生成导入 JSON，不需要生成 composite_context。",
      "composite_context 是系统内部 normalize / workspace / persistence 使用的 canonical 契约。"
    ]
  },
  "hard_constraints": [
    "只输出单个 JSON 对象",
    "不要输出 Markdown",
    "不要输出代码围栏",
    "不要输出解释文字",
    "不要输出注释",
    "不要发明新的 type",
    "不要输出嵌套 composite",
    "不要把 reading / cloze 放进 composite.questions",
    "所有 id 必须唯一",
    "所有 score 必须是数字",
    "JSON 必须可解析"
  ],
