        "prompt": "简述第二范式与第三范式的区别。",
        "score": 6,
        "response_format": "plain_text",
        "answer": {
          "reference_answer": "第二范式要求非主属性完全函数依赖于候选键，第三范式进一步要求不存在非主属性对候选键的传递依赖。",
          "scoring_points": [
            "说明第二范式核心要求",
            "说明第三范式核心要求",
            "指出第三范式比第二范式更严格"
          ]
        }
      }
    },
    "calculation": {
      "required": [
        "id",
        "type",
        "prompt",
        "score"
      ],
