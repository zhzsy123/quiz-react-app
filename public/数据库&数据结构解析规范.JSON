{
  "document_type": "quiz_import_spec",
  "document_version": "2026-04-v1",
  "title": "数据库&数据结构解析规范",
  "scope": {
    "subjects": [
      "database",
      "data_structure"
    ],
    "purpose": "将数据库与数据结构试卷解析为可导入 quiz-react-app 的合法 JSON"
  },
  "sample_insights": {
    "observed_question_types": [
      "single_choice",
      "fill_blank",
      "true_false",
      "short_answer",
      "calculation",
      "operation",
      "case_analysis",
      "composite"
    ],
    "common_database_scenarios": [
      "SQL 填空",
      "SQL / 关系代数分析",
      "事务与并发分析",
      "E-R 图与关系模式设计",
      "规范化分析",
      "综合材料题"
    ],
    "common_data_structure_scenarios": [
      "单选与判断基础概念题",
      "填空题",
      "算法过程题",
      "树 / 图遍历题",
      "哈夫曼树 / 最小生成树 / 拓扑序列",
      "综合应用题"
    ]
  },
  "top_level_schema": {
    "type": "object",
    "required": [
      "schema_version",
      "title",
      "subject",
      "questions"
    ],
    "properties": {
      "schema_version": {
        "type": "string",
        "const": "2026-04"
      },
      "title": {
        "type": "string",
        "description": "试卷标题"
      },
      "subject": {
        "type": "string",
        "enum": [
          "database",
          "data_structure"
        ]
      },
      "questions": {
        "type": "array",
        "description": "题目数组"
      }
    }
  },
  "allowed_types": [
    "single_choice",
    "multiple_choice",
    "true_false",
    "fill_blank",
    "short_answer",
    "calculation",
    "operation",
    "case_analysis",
    "composite"
  ],
  "type_mapping_rules": [
    {
      "source_pattern": "单选题",
      "target_type": "single_choice"
    },
    {
      "source_pattern": "多选题",
      "target_type": "multiple_choice"
    },
    {
      "source_pattern": "判断题",
      "target_type": "true_false"
    },
    {
      "source_pattern": "填空题 / SQL 填空 / 代码填空",
      "target_type": "fill_blank"
    },
    {
      "source_pattern": "简答题 / 解释题",
      "target_type": "short_answer"
    },
    {
      "source_pattern": "算法过程题 / 计算题 / 推导题",
      "target_type": "calculation"
    },
    {
      "source_pattern": "E-R 图 / 关系模式设计 / 模式分解",
      "target_type": "operation"
    },
    {
      "source_pattern": "事务分析 / 并发分析 / 规范化分析 / 关系代数分析",
      "target_type": "case_analysis"
    },
    {
      "source_pattern": "共享材料 + 多个子题",
      "target_type": "composite"
    }
  ],
  "general_question_fields": {
    "required": [
      "id",
      "type",
      "prompt",
      "score"
    ],
    "optional": [
      "context",
      "context_title",
      "context_format",
      "material",
      "material_title",
      "material_format",
      "presentation",
      "deliverable_type",
      "response_format",
      "tags",
      "assets"
    ]
  },
  "format_guidelines": {
    "context_format": [
      "plain",
      "markdown",
      "code",
      "sql"
    ],
    "material_format": [
      "plain",
      "markdown",
      "code",
      "sql"
    ],
    "presentation": [
      "plain",
      "code",
      "sql"
    ],
    "deliverable_type_examples": [
      "er_diagram",
      "relation_schema",
      "normalization_result",
      "transaction_analysis",
      "algorithm_trace"
    ],
    "response_format_examples": [
      "plain_text",
      "steps",
      "schema",
      "analysis"
    ]
  },
  "type_specs": {
    "single_choice": {
      "required": [
        "id",
        "type",
        "prompt",
        "score",
        "options",
        "answer.correct"
      ],
      "example": {
        "id": "q1",
        "type": "single_choice",
        "prompt": "关系数据库中，主键的作用是？",
        "score": 2,
        "options": [
          "A. 唯一标识元组",
          "B. 存储事务日志",
          "C. 表示外键依赖",
          "D. 控制并发"
        ],
        "answer": {
          "correct": "A"
        }
      }
    },
    "multiple_choice": {
      "required": [
        "id",
        "type",
        "prompt",
        "score",
        "options",
        "answer.correct"
      ],
      "example": {
        "id": "q2",
        "type": "multiple_choice",
        "prompt": "下列哪些属于关系数据库特性？",
        "score": 3,
        "options": [
          "A. 数据独立性",
          "B. 事务一致性",
