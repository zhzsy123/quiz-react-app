    "true_false": {
      "required": [
        "id",
        "type",
        "prompt",
        "score",
        "answer.correct"
      ],
      "example": {
        "id": "q3",
        "type": "true_false",
        "prompt": "B+ 树的叶子节点通常按照关键字有序链接。",
        "score": 1,
        "answer": {
          "correct": "T"
