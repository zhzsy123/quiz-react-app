        "type": "calculation",
        "prompt": "写出冒泡排序第一趟结束后的结果，并说明交换过程。",
        "score": 8,
        "deliverable_type": "algorithm_trace",
        "response_format": "steps",
        "answer": {
          "reference_answer": "第一趟后结果为 ...，交换过程为 ...",
