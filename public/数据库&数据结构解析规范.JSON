      }
    },
    "fill_blank": {
      "required": [
        "id",
        "type",
        "prompt",
        "score",
        "answer.correct"
      ],
      "example": {
        "id": "q4",
        "type": "fill_blank",
        "prompt": "补全 SQL 语句。",
        "score": 3,
