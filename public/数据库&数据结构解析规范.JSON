      "required": [
        "id",
        "type",
        "prompt",
        "score"
      ],
      "example": {
        "id": "q7",
        "type": "operation",
        "prompt": "根据业务描述设计该系统的关系模式。",
        "score": 10,
        "deliverable_type": "relation_schema",
        "response_format": "schema",
        "answer": {
          "reference_answer": "Student(sid, name, class_id), Class(class_id, class_name)",
